#include <stdio.h>
#include <string.h>
#include <math.h>

int main() {
    char hex[20];
    int len, i, dec=0, base=1;

    scanf("%s", hex);
    len = strlen(hex);

    for(i=len-1;i>=0;i--){
        if(hex[i]>='0' && hex[i]<='9')
            dec += (hex[i]-48)*base;
        else
            dec += (hex[i]-55)*base;

        base *= 16;
    }

    printf("%d", dec);
}
