#include <stdio.h>

int main(){
    int arr[]={5,1,4,2,8}, n=5;
    int max=0, second=0;

    for(int i=0;i<n;i++){
        if(arr[i]>max){
            second=max;
            max=arr[i];
        }
        else if(arr[i]>second && arr[i]!=max)
            second=arr[i];
    }
    printf("Second Largest: %d",second);
}
