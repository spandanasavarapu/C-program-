#include <stdio.h>
int main(){
    int a[100], b[100], n, i, flag=1;
    scanf("%d",&n);

    for(i=0;i<n;i++) scanf("%d",&a[i]);
    for(i=0;i<n;i++) scanf("%d",&b[i]);

    for(i=0;i<n;i++){
        if(a[i]!=b[i]){
            flag=0; break;
        }
    }

    if(flag) printf("Equal");
    else printf("Not Equal");
}
