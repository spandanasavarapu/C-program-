#include <stdio.h>
int main() 
{
    int n, count = 0, num = 2, sum = 0;
printf("Enter n: ");
    scanf("%d", &n);
  while(count < n)
{
        int isPrime = 1;
for(int i = 2; i <= num/2; i++) 
{
            if(num % i == 0) 
{
                isPrime = 0;
                break;
            }
        }

        if(isPrime) {
            sum += num;
            count++;
        }

        num++;
    }

    printf("Sum = %d", sum);
    return 0;
}
