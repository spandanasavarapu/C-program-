#include <stdio.h>
int main()
{
    int n, even = 0, odd = 0;
    printf("Enter n: ");
    scanf("%d", &n);

    for(int i = 1; i <= n; i++)
{
        if(i % 2 == 0)
            even += i;
        else
            odd += i;
    }

    printf("Even sum = %d\nOdd sum = %d", even, odd);
    return 0;
}
