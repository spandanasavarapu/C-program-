#include <stdio.h>
#include <string.h>
struct contact {
    char name[50], phone[15];
};
int main(){
    struct contact c[10];
    int n,i;
    char search[50];

    scanf("%d",&n);
    for(i=0;i<n;i++)
        scanf("%s %s", c[i].name, c[i].phone);

    scanf("%s", search);

    for(i=0;i<n;i++){
        if(strcmp(c[i].name, search)==0)
            printf("%s %s", c[i].name, c[i].phone);
    }
}
