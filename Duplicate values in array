#include <stdio.h>

int main() {
    int arr[] = {10, 20, 30, 20, 40, 10};
    int n = 6;

    printf("Duplicate elements: ");

    for(int i = 0; i < n; i++) {
        for(int j = i + 1; j < n; j++) {
            if(arr[i] == arr[j]) {
                printf("%d ", arr[i]);
                break;
            }
        }
    }
    return 0;
}
