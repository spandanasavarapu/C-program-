#include <stdio.h>
int main(){
    char s[100], sub[50];
    int i,j,k,flag;

    scanf("%s %s", s, sub);

    for(i=0;s[i];i++){
        flag=1;
        for(j=0;sub[j];j++){
            if(s[i+j]!=sub[j]){
                flag=0; break;
            }
        }
        if(flag){
            printf("Found at %d", i);
            return 0;
        }
    }
    printf("Not Found");
}
