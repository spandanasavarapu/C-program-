#include <stdio.h>
#include <string.h>
int main(){
    char s[100], word[50], max[50];
    int i=0, j=0, maxlen=0;

    gets(s);

    while(1){
        if(s[i]==' ' || s[i]=='\0'){
            word[j]='\0';
            if(j>maxlen){
                maxlen=j;
                strcpy(max, word);
            }
            j=0;
            if(s[i]=='\0') break;
        } else {
            word[j++]=s[i];
        }
        i++;
    }

    printf("Longest=%s", max);
}
