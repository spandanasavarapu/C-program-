#include <stdio.h>

int main() {
    int n, i = 2, flag = 1;

    printf("Enter number: ");
    scanf("%d", &n);

    if (n <= 1)
        flag = 0;

    while (i <= n / 2) {
        if (n % i == 0) {
            flag = 0;
            break;
        }
        i++;
    }

    if (flag)
        printf("Prime number");
    else
        printf("Not a prime number");

    return 0;
}
